---
permalink: /search.json
---
[
{%- for post in site.posts -%}
{%- assign subj_en = "" -%}{%- assign subj_es = "" -%}
{%- assign psubj = post.subject | replace: " ", "" | prepend: "," | append: "," -%}
{%- for v in site.data.verticals -%}{%- for s in v.subjects -%}{%- assign skey = s.slug | prepend: "," | append: "," -%}{%- if psubj contains skey -%}{%- if subj_en == "" -%}{%- assign subj_en = s.en -%}{%- assign subj_es = s.es -%}{%- else -%}{%- assign subj_en = subj_en | append: " · " | append: s.en -%}{%- assign subj_es = subj_es | append: " · " | append: s.es -%}{%- endif -%}{%- endif -%}{%- endfor -%}{%- endfor -%}
{
"title": {{ post.title | jsonify }},
"subtitle": {{ post.subtitle | default: "" | jsonify }},
"url": {{ post.url | relative_url | jsonify }},
"lang": {{ post.lang | default: "" | jsonify }},
"subject_en": {{ subj_en | jsonify }},
"subject_es": {{ subj_es | jsonify }},
"date": {{ post.date | date: "%Y-%m-%d" | jsonify }},
"content": {{ post.content | strip_html | normalize_whitespace | jsonify }}
}{%- unless forloop.last -%},{%- endunless -%}
{%- endfor -%}
]
